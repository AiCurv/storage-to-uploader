# ─────────────────────────────────────────────────────────────────────────────
# Environment Variables Required by StreamToBuffer Bot
# ─────────────────────────────────────────────────────────────────────────────
# This file lists ALL env vars used by the project. NEVER put real values here.
# Real values live in:
#   • Vercel project env (https://vercel.com/.../storage-to-uploader/settings/env)
#   • GitHub repo secrets (https://github.com/AiCurv/storage-to-uploader/settings/secrets)
#
# Why both? Vercel uses them at runtime (Telegram webhook, Gcore API, result callback).
# GitHub Actions uses them at workflow runtime (download + upload to storage.to/pixeldrain).
# Some secrets (BOT_VERIFY_TOKEN, TELEGRAM_BOT_TOKEN, TELEGRAM_ALLOWED_ID,
# STORAGE_TO_VISITOR_TOKEN) must be set in BOTH places with identical values.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Telegram ────────────────────────────────────────────────────────────────
# Bot token from @BotFather (format: "123456789:ABC...")
# Used in: Vercel + GitHub
TELEGRAM_BOT_TOKEN=

# Numeric Telegram user ID of the bot owner (the bot ONLY responds to this user)
# Find yours via @userinfobot
# Used in: Vercel + GitHub
TELEGRAM_ALLOWED_ID=

# Numeric Telegram channel ID (negative number, starts with -100...)
# Currently unused — kept for future channel-post features
# Used in: Vercel + GitHub
TELEGRAM_CHANNEL_ID=

# ─── Vercel ↔ GitHub Actions shared secret ────────────────────────────────────
# 64-hex-char token used to authenticate the GitHub Actions → Vercel /api/result
# callback. Must be IDENTICAL in Vercel env and GitHub secret.
# Used in: Vercel (BOT_VERIFY_TOKEN) + GitHub (BOT_VERIFY_TOKEN)
BOT_VERIFY_TOKEN=

# ─── GitHub ──────────────────────────────────────────────────────────────────
# PAT (personal access token) used by Vercel to trigger repository_dispatch
# Used in: Vercel + GitHub
GH_TOKEN=

# Repository slug
# Used in: Vercel
GITHUB_REPO=AiCurv/storage-to-uploader

# ─── storage.to ──────────────────────────────────────────────────────────────
# Visitor token for storage.to upload ownership tracking
# Used in: Vercel + GitHub
STORAGE_TO_VISITOR_TOKEN=

# ─── PixelDrain ──────────────────────────────────────────────────────────────
# API key for PixelDrain uploads (HTTP Basic Auth, empty username)
# Used in: GitHub ONLY (Vercel does not need it)
PIXELDRAIN_TOKEN=

# ─── GCore CDN (Instant CDN Stream feature) ──────────────────────────────────
# Used in: Vercel ONLY (GitHub Actions does not need them)
# Get these from https://portal.gcore.com/cdn/resources
GCORE_API_TOKEN=
GCORE_CDN_RESOURCE_ID=
GCORE_CDN_CNAME=

# ─── Setup helper ────────────────────────────────────────────────────────────
# Required to call /api/start (re-registers webhook & bot menu)
# Used in: Vercel
SETUP_SECRET=

# Auto-injected by Vercel CLI — do not set manually
# VERCEL_PROJECT_URL=storage-to-uploader.vercel.app
